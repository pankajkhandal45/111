{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build API Server",
      "type": "shell",
      "command": "pnpm run build",
      "options": {
        "cwd": "${workspaceFolder}/artifacts/api-server"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "label": "API Build"
      }
    },
    {
      "label": "Start API Server",
      "type": "shell",
      "command": "node --enable-source-maps ./dist/index.mjs",
      "options": {
        "cwd": "${workspaceFolder}/artifacts/api-server"
      },
      "dependsOn": ["Build API Server"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*$",
          "endsPattern": "Server listening"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "label": "API Server (port 8080)"
      }
    },
    {
      "label": "Start Frontend",
      "type": "shell",
      "command": "pnpm run dev",
      "options": {
        "cwd": "${workspaceFolder}/artifacts/chess-platform"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*$",
          "endsPattern": "ready in"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "label": "Frontend (port 5173)"
      }
    },
    {
      "label": "🚀 Run Chess App (Both Servers)",
      "dependsOn": ["Start API Server", "Start Frontend"],
      "dependsOrder": "sequence",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always"
      }
    }
  ]
}
